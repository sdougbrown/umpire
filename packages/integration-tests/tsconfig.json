{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["bun-types"],
    "paths": {
      "@umpire/core": ["../core/src/index.ts"],
      "@umpire/core/*": ["../core/src/*"],
      "@umpire/devtools": ["../devtools/src/index.ts"],
